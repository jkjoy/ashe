source "https://rubygems.org"

# 兼容当前本机 Ruby 版本的 Jekyll 主依赖。
gem "jekyll", "~> 4.2.2"

# 首页分页，足够支撑 Ashe 原主题的博客分页样式。
gem "jekyll-paginate", "~> 1.1"

# public_suffix 7.x requires Ruby >= 3.2, while the GitHub Pages workflow uses Ruby 3.1.
gem "public_suffix", "< 7.0"

# Ruby 3 以下本地 serve/build 环境常用的 HTTP 依赖。
gem "webrick", "~> 1.8"

